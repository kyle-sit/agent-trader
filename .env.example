# Market Intel example environment
# Copy to ~/market-intel/.env for project-local config, or to ~/.hermes/.env for shared config.
# Project-local .env takes precedence over ~/.hermes/.env.

# Market data / brokerage
FINNHUB_API_KEY=
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# LLM providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_TOKEN=

# Optional alerts
DISCORD_WEBHOOK_URL=

# Optional X / Twitter credentials usually live in separate local auth stores.
# AUTH_TOKEN=
# CT0=
